{
  "name": "codex-skills-manager",
  "version": "0.1.0",
  "description": "Windows desktop manager for local Codex skills.",
  "main": "out/main/index.js",
  "license": "MIT",
  "author": "Codex Skills Manager contributors",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "dist": "npm run build && electron-builder --win portable zip",
    "dist:portable": "npm run build && electron-builder --win portable",
    "pack": "npm run build && electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest",
    "test:run": "vitest run",
    "start": "electron-vite preview"
  },
  "build": {
    "appId": "local.codex.skills-manager",
    "productName": "Codex 技能管理器",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Codex-Skills-Manager-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
